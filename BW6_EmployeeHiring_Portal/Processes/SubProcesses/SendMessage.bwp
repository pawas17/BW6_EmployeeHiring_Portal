                        <tibex:inputBinding
                            expression="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#xa;&lt;xsl:stylesheet xmlns:xsl=&quot;http://www.w3.org/1999/XSL/Transform&quot; xmlns:tns=&quot;http://www.tibco.com/namespaces/tnt/plugins/jms+af1bd28d-4195-43af-9149-ac4ab2c87159+input&quot; xmlns:tns1=&quot;http://www.example.org/RecruitingCandidate&quot; xmlns:tns2=&quot;http://com.tibco.bw.plugin.jms.properties99bdc94e-1a40-465e-8b63-de6e1137b7a4NewJMSApplicationProperties&quot; version=&quot;2.0&quot;>&#xa;    &lt;xsl:param name=&quot;operationIn.parameters&quot;/>&#xa;    &lt;xsl:param name=&quot;OnRollCandidateType&quot;/>&#xa;    &lt;xsl:template name=&quot;JMSSendMessage-input&quot; match=&quot;/&quot;>&#xa;        &lt;tns:ActivityInput>&#xa;            &lt;Body>&#xa;                &lt;tns1:Candidate-Details>&#xa;                    &lt;tns1:CandidateID>&#xa;                        &lt;xsl:value-of select=&quot;$operationIn.parameters/tns1:CandidateID&quot;/>&#xa;                    &lt;/tns1:CandidateID>&#xa;                    &lt;tns1:CandidateName>&#xa;                        &lt;xsl:value-of select=&quot;$operationIn.parameters/tns1:CandidateName&quot;/>&#xa;                    &lt;/tns1:CandidateName>&#xa;                    &lt;xsl:for-each select=&quot;$operationIn.parameters/tns1:Candidate-Address&quot;>&#xa;                        &lt;tns1:Candidate-Address>&#xa;                            &lt;tns1:Street>&#xa;                                &lt;xsl:value-of select=&quot;tns1:Street&quot;/>&#xa;                            &lt;/tns1:Street>&#xa;                            &lt;tns1:LaneNo>&#xa;                                &lt;xsl:value-of select=&quot;tns1:LaneNo&quot;/>&#xa;                            &lt;/tns1:LaneNo>&#xa;                            &lt;tns1:City>&#xa;                                &lt;xsl:value-of select=&quot;tns1:City&quot;/>&#xa;                            &lt;/tns1:City>&#xa;                            &lt;tns1:Pincode>&#xa;                                &lt;xsl:value-of select=&quot;tns1:Pincode&quot;/>&#xa;                            &lt;/tns1:Pincode>&#xa;                            &lt;tns1:Country>&#xa;                                &lt;xsl:value-of select=&quot;tns1:Country&quot;/>&#xa;                            &lt;/tns1:Country>&#xa;                        &lt;/tns1:Candidate-Address>&#xa;                    &lt;/xsl:for-each>&#xa;                    &lt;xsl:for-each select=&quot;$operationIn.parameters/tns1:skill&quot;>&#xa;                        &lt;tns1:skill>&#xa;                            &lt;xsl:for-each select=&quot;tns1:technology&quot;>&#xa;                                &lt;tns1:technology>&#xa;                                    &lt;xsl:value-of select=&quot;.&quot;/>&#xa;                                &lt;/tns1:technology>&#xa;                            &lt;/xsl:for-each>&#xa;                        &lt;/tns1:skill>&#xa;                    &lt;/xsl:for-each>&#xa;                    &lt;tns1:Annual-Package>&#xa;                        &lt;xsl:value-of select=&quot;$operationIn.parameters/tns1:Annual-Package&quot;/>&#xa;                    &lt;/tns1:Annual-Package>&#xa;                &lt;/tns1:Candidate-Details>&#xa;            &lt;/Body>&#xa;            &lt;tns:OtherProperties>&#xa;                &lt;tns2:CandidateType>&#xa;                    &lt;xsl:value-of select=&quot;$OnRollCandidateType&quot;/>&#xa;                &lt;/tns2:CandidateType>&#xa;            &lt;/tns:OtherProperties>&#xa;        &lt;/tns:ActivityInput>&#xa;    &lt;/xsl:template>&#xa;&lt;/xsl:stylesheet>" expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xslt1.0"/>
                    </tibex:inputBindings>
